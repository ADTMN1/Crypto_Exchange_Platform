# ----------------------------------
# 1. NODE ENVIRONMENT
# ----------------------------------
# Set to 'production' for live deployment, 'development' for local testing
NODE_ENV=development

# ----------------------------------
# 2. SERVER CONFIGURATION
# ----------------------------------
# Port to run the backend server on
PORT=5000

# URL of your frontend (for password reset links, CORS, etc.)
FRONTEND_URL=http://localhost:5173

# ----------------------------------
# 3. DATABASE CONFIGURATION
# ----------------------------------
# PostgreSQL connection URL
DATABASE_URL=postgresql://neondb_owner:npg_QZJEPMd6z3Hs@ep-patient-wind-aqn7uwgv-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Redis connection URL
REDIS_URL=redis://localhost:6379

# ----------------------------------
# 4. SECURITY CONFIGURATION
# ----------------------------------
# JWT SECRETS - THESE MUST BE LONG, RANDOM, AND SECRET!
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_jwt_secret_here
REFRESH_SECRET=your_strong_refresh_secret_here

# Cookie secret - for signing cookies
COOKIE_SECRET=your_strong_cookie_secret_here

# ----------------------------------
# 5. EMAIL CONFIGURATION (Resend)
# ----------------------------------
# Get your API key from https://resend.com
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=Crypto Exchange <onboarding@resend.dev>


# ----------------------------------
# 6. BINANCE API CONFIGURATION
# ----------------------------------
# Binance Futures API base URLs (default to Binance's public Futures API)
BINANCE_REST_BASEURL=https://fapi.binance.com
BINANCE_WS_BASEURL=wss://fstream.binance.com/ws

# ----------------------------------
# 7. WALLET & CRYPTO CONFIGURATION
# ----------------------------------
# BIP-39 MNEMONIC - KEEP THIS SECRET! NEVER COMMIT TO GIT!
# Generate your own mnemonic using tools like: https://iancoleman.io/bip39/
WALLET_MNEMONIC=your_12_24_word_mnemonic_here

# DEFAULT NETWORK
# Options: ETH (Ethereum), BSC (Binance Smart Chain), MATIC (Polygon), etc.
DEFAULT_NETWORK=ETH

# RPC URL - use a reliable service like Ankr, Infura, or Alchemy
# For production, use a paid plan for better reliability
# Ethereum Mainnet: https://rpc.ankr.com/eth
# Binance Smart Chain (BSC): https://rpc.ankr.com/bsc
# Polygon (MATIC): https://rpc.ankr.com/polygon
# Ethereum Sepolia Testnet: https://rpc.ankr.com/eth_sepolia
DEFAULT_RPC_URL=https://rpc.ankr.com/eth

# NUMBER OF CONFIRMATIONS REQUIRED TO CREDIT DEPOSITS
# For production, use 6-12 confirmations for security
CONFIRMATIONS_REQUIRED=6

# DEPOSIT SCANNER INTERVAL (cron format)
# How often to scan blockchain for deposits
# Default is every 30 seconds (*/30 * * * * *)
DEPOSIT_SCAN_INTERVAL=*/30 * * * * *

# ----------------------------------
# 7. DEVELOPMENT-ONLY CONFIGURATION
# ----------------------------------
# THESE ARE ONLY USED WHEN NODE_ENV=development
# They are IGNORED in production!

# Initial USDT balance to give new users in development mode (for testing)
TEST_INITIAL_USDT=1000

# ----------------------------------
# 8. PRODUCTION SECURITY CHECKLIST
# ----------------------------------
# ✅ Set NODE_ENV=production
# ✅ Use strong, unique secrets for JWT_SECRET, REFRESH_SECRET, COOKIE_SECRET
# ✅ Use a paid RPC provider (Infura, Alchemy, etc.) for reliability
# ✅ Store WALLET_MNEMONIC in a secure vault (not .env file in production!)
# ✅ Use HTTPS with a valid SSL certificate
# ✅ Set up proper CORS headers
# ✅ Enable rate limiting
# ✅ Set up monitoring and logging
# ✅ Back up your database regularly
# ✅ Consider using a hardware security module (HSM) for key management
